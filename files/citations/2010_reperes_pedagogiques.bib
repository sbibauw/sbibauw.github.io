@article{bibauw2010pratiques
  title = {Les pratiques d'écriture réflexive en contexte de formation générale},
  volume = {1},
  url = {https://halshs.archives-ouvertes.fr/hal-00798613/document},
  abstract = {"Dans cet article de synthèse, nous nous faisons d’abord le point sur les différentes approches qui sont faites de la réflexivité, et en particulier des pratiques d’écriture réflexive, en contexte pédagogique. Nous étudions ensuite les tensions auxquelles est confronté un enseignant qui souhaite engager ses apprenants dans des pratiques réflexives dans un contexte de formation générale, non professionnalisante, et en particulier dans le contexte de la transition entre l’enseignement secondaire et l’enseignement supérieur. Ces tensions opposent différentes modalités possibles d’une pratique réflexive, qui correspondent à une diversité d’effets et d’enjeux.},
  number = {2},
  urldate = {2017-07-19},
  journal = {Repères pédagogiques, revue andragogique marocaine},
  author = {Bibauw, Serge and Dufays, Jean-Louis},
  year = {2010},
  pages = {13--29},
  language = {fr}
}
